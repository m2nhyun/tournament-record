# For db migration automation
# Use URL-encoded passwords. Example: p@ssword -> p%40ssword
SUPABASE_DB_URL=postgresql://postgres:<url-encoded-password>@db.<project-ref>.supabase.co:5432/postgres
# Optional override for IPv4-only environments where direct 5432 access is blocked.
# Fill this with the Session pooler string from Supabase Dashboard > Connect.
SUPABASE_DB_PUSH_URL=postgresql://postgres.<project-ref>:<url-encoded-password>@aws-0-<region>.pooler.supabase.com:5432/postgres
